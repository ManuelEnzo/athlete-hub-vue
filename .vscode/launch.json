{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Nuxt: Debug",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "pathMapping": {
        "/_nuxt": "${workspaceFolder}"
      },
      "sourceMapPathOverrides": {
        "webpack:///./*": "${webRoot}/*",
        "node_modules/*": "${webRoot}/node_modules/*"
      }
    }
  ]
}